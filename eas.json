{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://your-backend-url/api/v1",
        "EXPO_PUBLIC_DEMO_MODE": "false"
      }
    },
    "demo": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://your-backend-url/api/v1",
        "EXPO_PUBLIC_DEMO_MODE": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}